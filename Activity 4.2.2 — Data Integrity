<script>
function previewImg(input) {
  if (!input.files || !input.files[0]) return;
  const reader = new FileReader();
  reader.onload = e => {
    const area = input.closest('.ss-area');
    const img = area.querySelector('img');
    area.querySelector('.icon').style.display = 'none';
    area.querySelector('p').style.display = 'none';
    img.src = e.target.result;
    img.style.display = 'block';
  };
  reader.readAsDataURL(input.files[0]);
}

function toggleSpoiler(btn) {
  const c = btn.nextElementSibling;
  c.classList.toggle('open');
  btn.querySelector('span').textContent = c.classList.contains('open') ? '▲' : '▼';
}

// Paste image into whichever ss-area the mouse is over (or first one)
document.addEventListener('paste', e => {
  const items = e.clipboardData?.items;
  if (!items) return;
  for (const item of items) {
    if (item.type.startsWith('image/')) {
      const blob = item.getAsFile();
      const area = document.querySelector('.ss-area:hover') || document.querySelector('.ss-area');
      if (!area) return;
      const reader = new FileReader();
      reader.onload = ev => {
        const img = area.querySelector('img');
        const ic = area.querySelector('.icon');
        const p = area.querySelector('p');
        if (ic) ic.style.display = 'none';
        if (p) p.style.display = 'none';
        img.src = ev.target.result;
        img.style.display = 'block';
      };
      reader.readAsDataURL(blob);
      e.preventDefault();
      break;
    }
  }
});
</script>
